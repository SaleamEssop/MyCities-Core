# MyCities-Core — Copy to .env and set values. No quotes needed for values.
# Required on server: set APP_URL and APP_KEY (run: docker exec mycities-core-laravel php artisan key:generate --show).

APP_NAME=MyCities-Core
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_KEY=

DB_DATABASE=mycities_core
DB_USERNAME=mycities_core_user
DB_PASSWORD=MyCitiesCorePass!
DB_ROOT_PASSWORD=MyCitiesCoreRoot!
DB_PORT=3307

HTTP_PORT=80
